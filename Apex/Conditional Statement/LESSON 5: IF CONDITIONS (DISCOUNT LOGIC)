      "Your change is: $3.25"
========================================== */

Decimal coffee=4.00;
Decimal pastry=3.50;
Decimal TotalCost=coffee+pastry;
Decimal Temp =7.00;
Decimal Inhandamount=10;
Decimal Discount=TotalCost- (TotalCost*0.10);
Decimal balance=Inhandamount-Discount;

If(TotalCost > Temp)
{
System.debug('Your change is:' +'$' +balance);
}
Else
{
System.debug('no discount');
}










